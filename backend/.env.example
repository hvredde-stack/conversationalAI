# GCP / Firebase
GCP_PROJECT_ID=convai-prod-001
GCP_LOCATION=us-central1

# Path to the service account JSON key (LOCAL DEV ONLY — on Cloud Run, leave unset)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Firebase project ID (usually same as GCP_PROJECT_ID)
FIREBASE_PROJECT_ID=convai-prod-001

# Cloud Storage bucket for uploads
GCS_UPLOADS_BUCKET=convai-prod-001-uploads

# Vertex AI — gemini-3.5-flash is served only via the "global" endpoint
VERTEX_LOCATION=global
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FAST_MODEL=gemini-3.5-flash

# App
APP_ENV=dev
LOG_LEVEL=INFO

# CORS — frontend origin during dev
FRONTEND_ORIGIN=http://localhost:5173
